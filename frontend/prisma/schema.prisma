// Prisma schema for Pavitrarpan Foundation
// Using SQLite for local development

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      String   @default("admin")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model Event {
  id               Int      @id @default(autoincrement())
  title            String
  description      String
  banner           String?
  date             DateTime
  time             String?
  venue            String
  registrationLink String?
  status           String   @default("upcoming")
  featured         Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("events")
}

model GalleryAlbum {
  id                   Int      @id @default(autoincrement())
  title                String
  eventDate            DateTime
  googleDriveFolderId  String
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@map("gallery_albums")
}

model WebsiteContent {
  id        Int      @id @default(autoincrement())
  about     String
  mission   String
  vision    String
  goals     String
  updatedAt DateTime @updatedAt

  @@map("website_content")
}

model Statistics {
  id                Int      @id @default(autoincrement())
  treesPlanted      Int      @default(0)
  cleanlinessDrives Int      @default(0)
  volunteers        Int      @default(0)
  studentsEducated  Int      @default(0)
  eventsConducted   Int      @default(0)
  updatedAt         DateTime @updatedAt

  @@map("statistics")
}

model Message {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  subject   String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("messages")
}
