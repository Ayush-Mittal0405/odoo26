// EcoSphere ESG Management Platform
// Prisma schema for PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum DepartmentStatus {
  ACTIVE
  INACTIVE
}

enum CategoryType {
  CSR_ACTIVITY
  CHALLENGE
}

enum CategoryStatus {
  ACTIVE
  INACTIVE
}

enum SourceType {
  PURCHASE
  MANUFACTURING
  EXPENSE
  FLEET
  MANUAL
}

enum CsrActivityStatus {
  DRAFT
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ChallengeDifficulty {
  EASY
  MEDIUM
  HARD
}

enum ChallengeStatus {
  DRAFT
  ACTIVE
  UNDER_REVIEW
  COMPLETED
  ARCHIVED
}

enum RewardStatus {
  ACTIVE
  OUT_OF_STOCK
  RETIRED
}

enum RedemptionStatus {
  PENDING
  FULFILLED
  CANCELLED
}

enum PolicyStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum AcknowledgementStatus {
  PENDING
  ACKNOWLEDGED
  OVERDUE
}

enum AuditStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
}

enum IssueSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum IssueStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  OVERDUE
}

// ---------------------------------------------------------------------------
// Master data
// ---------------------------------------------------------------------------

model Department {
  id                 String           @id @default(uuid())
  name               String
  code               String           @unique
  headEmployeeId     String?          @unique @map("head_employee_id")
  parentDepartmentId String?          @map("parent_department_id")
  employeeCount      Int              @default(0) @map("employee_count")
  status             DepartmentStatus @default(ACTIVE)
  createdAt          DateTime         @default(now()) @map("created_at")
  updatedAt          DateTime         @updatedAt @map("updated_at")

  headEmployee     Employee?          @relation("DepartmentHead", fields: [headEmployeeId], references: [id])
  parentDepartment Department?        @relation("DepartmentHierarchy", fields: [parentDepartmentId], references: [id])
  childDepartments Department[]       @relation("DepartmentHierarchy")
  employees        Employee[]         @relation("DepartmentEmployees")
  carbonTxns       CarbonTransaction[]
  csrActivities    CsrActivity[]
  environmentalGoals EnvironmentalGoal[]
  audits           Audit[]
  departmentScores DepartmentScore[]

  @@map("departments")
}

model Employee {
  id             String   @id @default(uuid())
  departmentId   String?  @map("department_id")
  name           String
  email          String   @unique
  role           String?
  xpTotal        Int      @default(0) @map("xp_total")
  pointsBalance  Int      @default(0) @map("points_balance")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  department              Department?             @relation("DepartmentEmployees", fields: [departmentId], references: [id])
  headOfDepartment        Department?             @relation("DepartmentHead")
  employeeParticipations  EmployeeParticipation[]
  challengeParticipations ChallengeParticipation[]
  employeeBadges          EmployeeBadge[]
  rewardRedemptions       RewardRedemption[]
  policyAcknowledgements  PolicyAcknowledgement[]
  ownedComplianceIssues   ComplianceIssue[]        @relation("IssueOwner")

  @@map("employees")
}

model Category {
  id     String         @id @default(uuid())
  name   String
  type   CategoryType
  status CategoryStatus @default(ACTIVE)

  csrActivities CsrActivity[]
  challenges    Challenge[]

  @@unique([name, type])
  @@map("categories")
}

model EmissionFactor {
  id             String   @id @default(uuid())
  activityType   String   @map("activity_type")
  unit           String
  co2PerUnit     Decimal  @map("co2_per_unit") @db.Decimal(12, 4)
  effectiveDate  DateTime @map("effective_date") @db.Date

  carbonTxns CarbonTransaction[]

  @@map("emission_factors")
}

model EnvironmentalGoal {
  id           String   @id @default(uuid())
  departmentId String   @map("department_id")
  metric       String
  targetValue  Decimal  @map("target_value") @db.Decimal(12, 2)
  currentValue Decimal  @default(0) @map("current_value") @db.Decimal(12, 2)
  deadline     DateTime @db.Date

  department Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  @@map("environmental_goals")
}

model EsgPolicy {
  id          String       @id @default(uuid())
  title       String
  description String?
  category    String?
  version     String
  status      PolicyStatus @default(DRAFT)
  effectiveDate DateTime?  @map("effective_date") @db.Date

  acknowledgements PolicyAcknowledgement[]

  @@map("esg_policies")
}

model Badge {
  id          String @id @default(uuid())
  name        String @unique
  description String?
  unlockRule  String @map("unlock_rule")
  icon        String?

  employeeBadges EmployeeBadge[]

  @@map("badges")
}

model Reward {
  id             String       @id @default(uuid())
  name           String
  description    String?
  pointsRequired Int          @map("points_required")
  stock          Int          @default(0)
  status         RewardStatus @default(ACTIVE)

  redemptions RewardRedemption[]

  @@map("rewards")
}

// ---------------------------------------------------------------------------
// Transactional data
// ---------------------------------------------------------------------------

model CarbonTransaction {
  id               String     @id @default(uuid())
  departmentId     String     @map("department_id")
  emissionFactorId String     @map("emission_factor_id")
  sourceType       SourceType @map("source_type")
  sourceRefId      String?    @map("source_ref_id")
  quantity         Decimal    @db.Decimal(14, 4)
  co2Emitted       Decimal    @map("co2_emitted") @db.Decimal(14, 4)
  txnDate          DateTime   @map("txn_date") @db.Date
  autoCalculated   Boolean    @default(false) @map("auto_calculated")
  createdAt        DateTime   @default(now()) @map("created_at")

  department     Department     @relation(fields: [departmentId], references: [id], onDelete: Restrict)
  emissionFactor EmissionFactor @relation(fields: [emissionFactorId], references: [id], onDelete: Restrict)

  @@index([departmentId])
  @@index([emissionFactorId])
  @@map("carbon_transactions")
}

model CsrActivity {
  id           String            @id @default(uuid())
  departmentId String            @map("department_id")
  categoryId   String            @map("category_id")
  title        String
  description  String?
  activityDate DateTime          @map("activity_date") @db.Date
  status       CsrActivityStatus @default(DRAFT)

  department   Department              @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  category     Category                @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  participations EmployeeParticipation[]

  @@index([departmentId])
  @@index([categoryId])
  @@map("csr_activities")
}

model EmployeeParticipation {
  id               String         @id @default(uuid())
  employeeId       String         @map("employee_id")
  activityId       String         @map("activity_id")
  proofFile        String?        @map("proof_file")
  approvalStatus   ApprovalStatus @default(PENDING) @map("approval_status")
  pointsEarned     Int            @default(0) @map("points_earned")
  completionDate   DateTime?      @map("completion_date") @db.Date

  employee Employee    @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  activity CsrActivity @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@unique([employeeId, activityId])
  @@index([activityId])
  @@map("employee_participations")
}

model Challenge {
  id                String              @id @default(uuid())
  categoryId        String              @map("category_id")
  title             String
  description       String?
  xp                Int
  difficulty        ChallengeDifficulty @default(MEDIUM)
  evidenceRequired  Boolean             @default(false) @map("evidence_required")
  deadline          DateTime?           @db.Date
  status            ChallengeStatus     @default(DRAFT)

  category       Category                 @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  participations ChallengeParticipation[]

  @@index([categoryId])
  @@map("challenges")
}

model ChallengeParticipation {
  id             String         @id @default(uuid())
  challengeId    String         @map("challenge_id")
  employeeId     String         @map("employee_id")
  progress       Decimal        @default(0) @db.Decimal(5, 2)
  proofFile      String?        @map("proof_file")
  approvalStatus ApprovalStatus @default(PENDING) @map("approval_status")
  xpAwarded      Int            @default(0) @map("xp_awarded")

  challenge Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  employee  Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([challengeId, employeeId])
  @@index([employeeId])
  @@map("challenge_participations")
}

model EmployeeBadge {
  id           String   @id @default(uuid())
  employeeId   String   @map("employee_id")
  badgeId      String   @map("badge_id")
  awardedDate  DateTime @default(now()) @map("awarded_date") @db.Date

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  badge    Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, badgeId])
  @@index([badgeId])
  @@map("employee_badges")
}

model RewardRedemption {
  id              String           @id @default(uuid())
  employeeId      String           @map("employee_id")
  rewardId        String           @map("reward_id")
  pointsDeducted  Int              @map("points_deducted")
  redemptionDate  DateTime         @default(now()) @map("redemption_date") @db.Date
  status          RedemptionStatus @default(PENDING)

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  reward   Reward   @relation(fields: [rewardId], references: [id], onDelete: Restrict)

  @@index([employeeId])
  @@index([rewardId])
  @@map("reward_redemptions")
}

model PolicyAcknowledgement {
  id                 String                @id @default(uuid())
  policyId           String                @map("policy_id")
  employeeId         String                @map("employee_id")
  acknowledgedDate   DateTime?             @map("acknowledged_date") @db.Date
  status             AcknowledgementStatus @default(PENDING)

  policy   EsgPolicy @relation(fields: [policyId], references: [id], onDelete: Cascade)
  employee Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([policyId, employeeId])
  @@index([employeeId])
  @@map("policy_acknowledgements")
}

model Audit {
  id           String      @id @default(uuid())
  departmentId String      @map("department_id")
  auditType    String      @map("audit_type")
  auditor      String?
  auditDate    DateTime    @map("audit_date") @db.Date
  status       AuditStatus @default(PLANNED)

  department        Department        @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  complianceIssues  ComplianceIssue[]

  @@index([departmentId])
  @@map("audits")
}

model ComplianceIssue {
  id               String        @id @default(uuid())
  auditId          String        @map("audit_id")
  severity         IssueSeverity
  description      String
  ownerEmployeeId  String        @map("owner_employee_id")
  dueDate          DateTime      @map("due_date") @db.Date
  status           IssueStatus   @default(OPEN)
  createdAt        DateTime      @default(now()) @map("created_at")

  audit         Audit    @relation(fields: [auditId], references: [id], onDelete: Restrict)
  ownerEmployee Employee @relation("IssueOwner", fields: [ownerEmployeeId], references: [id], onDelete: Restrict)

  @@index([auditId])
  @@index([ownerEmployeeId])
  @@map("compliance_issues")
}

model DepartmentScore {
  id                  String   @id @default(uuid())
  departmentId        String   @map("department_id")
  period              String
  environmentalScore  Decimal  @default(0) @map("environmental_score") @db.Decimal(5, 2)
  socialScore         Decimal  @default(0) @map("social_score") @db.Decimal(5, 2)
  governanceScore     Decimal  @default(0) @map("governance_score") @db.Decimal(5, 2)
  totalScore          Decimal  @default(0) @map("total_score") @db.Decimal(5, 2)
  calculatedAt        DateTime @default(now()) @map("calculated_at")

  department Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  @@unique([departmentId, period])
  @@map("department_scores")
}
